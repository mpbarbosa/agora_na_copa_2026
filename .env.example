# APP_URL: Public base URL for this app.
# Used for self-referential links and any server-generated absolute URLs.
APP_URL="MY_APP_URL"

# PORT: Express server listen port in local or production environments.
PORT="3000"

# REDDIT_CLIENT_ID / REDDIT_CLIENT_SECRET: OAuth credentials for the live
# "Repercussão no Reddit" feed (/api/reddit). Create an app at
# https://www.reddit.com/prefs/apps (type "web app" or "script"). Optional —
# when unset, /api/reddit serves the curated seed (src/data/redditPosts.json)
# as source:"fallback" and never fails.
REDDIT_CLIENT_ID=""
REDDIT_CLIENT_SECRET=""

# TRAFFIC_REPORTS_DIR: Directory holding the committed traffic snapshots
# (summary-*.txt) that back the Dashboard "Tráfego" tab (/api/traffic-dashboard).
# Optional — defaults to "<cwd>/traffic-reports" (correct in dev). In production
# the service runs from the deploy dir (/var/www/…), which does NOT carry the
# snapshots, so point this at the git checkout that generates them, e.g.
# /home/ubuntu/Documents/GitHub/agora_na_copa_2026/traffic-reports. When the dir
# is missing/empty the endpoint degrades to source:"fallback" (empty tab).
TRAFFIC_REPORTS_DIR=""

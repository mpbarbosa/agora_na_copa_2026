#!/usr/bin/env sh
# Tests-only pre-commit gate for "Agora na Copa 26".
#
# Runs the FAST suites (type-check + unit tests) and blocks the commit if they
# fail. The heavy e2e/Docker suite and the version bump + deploy stay in the
# /test-bump-deploy release pipeline — this hook never bumps, pushes, or deploys.
#
# Applies to every worktree via `core.hooksPath=.githooks` (see package.json
# "prepare", or run `git config core.hooksPath .githooks` once).
#
# Bypass for a work-in-progress commit:  git commit --no-verify
set -e

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

# The data worktree (agora-data) carries no node_modules — it only edits JSON
# data. Skip the gate there rather than blocking the commit on a missing
# toolchain. Any worktree without installed deps is treated the same way.
if [ ! -x "node_modules/.bin/tsc" ]; then
  echo "pre-commit: node_modules absent — skipping test gate (data/uninstalled worktree)."
  exit 0
fi

echo "pre-commit ▶ type-check (tsc --noEmit)…"
npm run lint --silent

echo "pre-commit ▶ unit tests…"
npm run test:unit --silent

echo "pre-commit ✓ checks passed"

{
  "name": "agora-na-copa-2026",
  "private": true,
  "version": "0.0.387",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "test:unit": "node --import tsx --test tests/fifa-sync-core.test.ts tests/trends-core.test.ts tests/weather-core.test.ts tests/venue-coordinates.test.ts tests/analysis-freshness.test.ts tests/match-speech.test.ts tests/disciplinary.test.ts tests/pix-brcode.test.ts tests/presence-core.test.ts tests/chat-core.test.ts tests/predict-core.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:prod": "playwright test --config=playwright.prod.config.ts",
    "sync-matches": "python3 scripts/sync-match-results.py --verbose",
    "deploy": "./scripts/deploy.sh",
    "deploy:preflight": "./scripts/deploy-preflight.sh",
    "go-live": "bash shell_scripts/10_go_live.sh"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "driver.js": "^1.4.0",
    "express": "^4.21.2",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-leaflet": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/express": "^4.17.21",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.28.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^8.0.16"
  }
}
